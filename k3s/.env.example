# DeerFlow K8s 部署环境变量
# 复制为 .env 后填写：  copy .env.example .env

# ── 源码仓库（deploy 脚本会自动 clone）──
DEER_FLOW_REPO=https://github.com/bytedance/deer-flow.git
DEER_FLOW_BRANCH=main
DEER_FLOW_SRC=../deer-flow

# ── 镜像标签 ──
IMAGE_TAG=latest
GATEWAY_IMAGE=deer-flow-gateway:latest
FRONTEND_IMAGE=deer-flow-frontend:latest
PROVISIONER_IMAGE=deer-flow-provisioner:latest

# ── 必填：LLM API Key（至少填一个）──
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=sk-c763ae2f20d5445b844b50c992d60fbb

# ── 认证密钥（留空则 deploy 脚本自动生成）──
BETTER_AUTH_SECRET=
DEER_FLOW_INTERNAL_AUTH_TOKEN=

# ── 可选：构建加速（国内网络）──
# Docker Hub / GHCR 镜像加速（Rancher nerdctl 构建时生效，无需 Docker Desktop）
# DOCKER_REGISTRY_MIRROR=https://docker.1ms.run
# GHCR_REGISTRY_MIRROR=https://docker.1ms.run
# APT_MIRROR=mirrors.aliyun.com
# UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# UV_HTTP_TIMEOUT=600
# UV_CONCURRENT_DOWNLOADS=2
# NPM_REGISTRY=https://registry.npmmirror.com
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# ── 集群配置 ──
K8S_NAMESPACE=deer-flow
NODE_PORT=32026
STORAGE_CLASS=local-path

# ── Sandbox 镜像 ──
SANDBOX_IMAGE=enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest

# ── NODE_HOST（留空则 deploy 自动检测节点 InternalIP）──
NODE_HOST=

# ── OpenViking 外置记忆（deploy 默认启用）──
OPENVIKING_ENABLED=true
# 国内推荐：南京大学 ghcr 镜像站（v0.3.24 含 CPU SIMD 运行时适配）
OPENVIKING_IMAGE=ghcr.nju.edu.cn/volcengine/openviking:v0.3.24
# 备选：华为云 SWR（latest 可能较旧，仅 v0.2.x）
# OPENVIKING_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/ghcr.io/volcengine/openviking:latest
# 海外或能直连 GHCR 时可改为：
# OPENVIKING_IMAGE=ghcr.io/volcengine/openviking:v0.3.24
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_API_BASE=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_EMBEDDING_MODEL=doubao-embedding-vision-251215
# VLM：默认 DeepSeek（与 DeerFlow config.yaml 主模型 deepseek-v4-pro 一致）
OPENVIKING_VLM_MODEL=deepseek-v4-pro
# OPENVIKING_VLM_API_BASE=https://api.deepseek.com/v1
# OPENVIKING_VLM_API_KEY=留空则复用 DEEPSEEK_API_KEY
# 若 VLM 也要走火山，可显式指定：
# OPENVIKING_VLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# OPENVIKING_VLM_API_KEY=
# VOLCENGINE_VLM_MODEL=doubao-seed-2-0-pro-260215
